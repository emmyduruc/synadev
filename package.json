{
  "name": "syna",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.9.2",
  "workspaces": [
    "client",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "node rules/i18n/check-locale-keys.mjs && turbo lint typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "prepare": "husky",
    "ios": "yarn workspace @syna/client ios",
    "android": "yarn workspace @syna/client android",
    "start:client": "yarn workspace @syna/client start"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "yarn": ">=4.0.0",
    "npm": "please-use-yarn"
  }
}
