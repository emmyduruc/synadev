{
  "expo": {
    "name": "SYNA",
    "slug": "syna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "syna",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syna.app"
    },
    "android": {
      "package": "com.syna.app",
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@clerk/expo",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "SYNA reads your health data to show patterns from your own wearable history.",
          "NSHealthUpdateUsageDescription": "SYNA does not write health data.",
          "background": true
        }
      ],
      "react-native-health-connect",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#6d2e46"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
